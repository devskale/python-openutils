# Proxy Configuration
PROXYHOST=localhost
PROXY_PORT=8123

# Rate Limiting
UNIINFER_RATE_LIMIT_CHAT="100/minute"
UNIINFER_RATE_LIMIT_EMBEDDINGS="200/minute"
UNIINFER_RATE_LIMIT_MEDIA="50/minute"

# Authentication
# Credgoo combined token (bearer@encryption) used as Bearer auth for the proxy.
# Tests and examples read this via os.getenv('PROXY_KEY').
# ⚠️ Never commit real tokens. .env is gitignored.
PROXY_KEY=your-bearer@your-encryption

# Credgoo Configuration (for key management)
# CREDGOO_BEARER_TOKEN=
# CREDGOO_ENCRYPTION_KEY=

# Provider Specific Keys (Fallback)
TU_API_KEY=
